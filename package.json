{
  "name": "salestoopzdesktop",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:ui\" \"npm:dev:api\" \"npm:dev:worker\" \"npm:dev:electron\"",
    "dev:ui": "cd frontend && npm run dev",
    "dev:api": "cd agent && venv\\Scripts\\uvicorn.exe main:app --host 127.0.0.1 --port 8715 --reload",
    "dev:worker": "cd agent && venv\\Scripts\\python.exe worker_main.py",
    "dev:electron": "set SALESTROOPZ_API_PORT=8715 && wait-on http://localhost:5173 && wait-on http-get://localhost:8715/health && electron .",
    "build": "npm run build:ui && npm run build:electron",
    "build:ui": "cd frontend && npm run build",
    "build:electron": "electron-builder"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^8.0.0"
  }
}
