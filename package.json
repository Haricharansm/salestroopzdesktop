{
  "name": "salestroopz-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:ui": "vite",
    "dev:electron": "concurrently -k -n UI,ELECTRON -c cyan,magenta \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build:ui": "vite build",
    "dist:api": "cd agent && pyinstaller -y pyinstaller/salestroopz_api.spec",
    "dist:runner": "cd agent && pyinstaller -y pyinstaller/salestroopz_runner.spec",
    "dist:backend": "npm run dist:api && npm run dist:runner",
    "dist:win": "npm run build:ui && npm run dist:backend && electron-builder --win --x64"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "ai.saxon.salestroopz.desktop",
    "productName": "Salestroopz Desktop",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**"
    ],
    "extraResources": [
    {
    "from": "dist/salestroopz_api/salestroopz_api.exe",
    "to": "bin/salestroopz_api.exe"
    },
    {
    "from": "dist/salestroopz_runner/salestroopz_runner.exe",
    "to": "bin/salestroopz_runner.exe"
    }
  ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Salestroopz Desktop"
    }
  }
}
