{
  "name": "salestroopz-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:ui": "cd frontend && vite",
    "dev:electron": "concurrently -k -n UI,ELECTRON -c cyan,magenta \"cd frontend && vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build:ui": "cd frontend && vite build",
    "dist:api": "pyinstaller -y agent/pyinstaller/salestroopz_api.spec",
    "dist:runner": "pyinstaller -y agent/pyinstaller/salestroopz_runner.spec",
    "dist:backend": "npm run dist:api && npm run dist:runner",
    "dist:win": "npm run build:ui && npm run dist:backend && electron-builder --win --x64"
  },
  "build": {
    "appId": "ai.saxon.salestroopz.desktop",
    "productName": "Salestroopz Desktop",
    "asar": true,
    "forceCodeSigning": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "frontend/dist/**",
      "electron/**"
    ],
    "extraResources": [
      {
        "from": "dist/salestroopz_api",
        "to": "bin/salestroopz_api"
      },
      {
        "from": "dist/salestroopz_runner",
        "to": "bin/salestroopz_runner"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Salestroopz Desktop"
    }
  }
}
